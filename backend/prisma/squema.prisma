datasource db {
    provider = "mysql"
}

generator client {
    provider = "prisma-client"
    output   = "./generated"
}

model Coche {
    id               Int    @id @default(autoincrement())
    modelo           String
    año             Int
    precio           Int
    color            String
    numero_puertas   Int
    tipo_combustible String
    imagen           String
    marcaId          Int
    marca            Marca  @relation(fields: [marcaId], references: [id])
}

model Marca {
    id     Int     @id @default(autoincrement())
    nombre String
    coches Coche[]
}
